---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title } = Astro.props;

const stripHtml = (html: string) => html.replace(/<[^>]*>/g, '');

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: stripHtml(item.answer),
    },
  })),
};
---

<section id="faq" class="py-12">
  {title && <h2 class="text-2xl font-bold text-dark mb-8">{title}</h2>}
  <div class="space-y-3">
    {items.map((item) => (
      <details class="group border border-border rounded-xl overflow-hidden bg-white hover:border-access-200 transition-colors">
        <summary class="flex items-center justify-between p-5 cursor-pointer hover:bg-access-50/50 transition-colors">
          <span class="font-semibold text-dark pe-4">{item.question}</span>
          <div class="w-8 h-8 rounded-full bg-surface flex items-center justify-center flex-shrink-0 group-open:bg-access-500 transition-colors">
            <svg class="w-4 h-4 text-gray-500 group-open:text-white transition-all group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </summary>
        <div class="px-5 pb-5 text-gray-600 leading-relaxed border-t border-border pt-4">
          <Fragment set:html={item.answer} />
        </div>
      </details>
    ))}
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
