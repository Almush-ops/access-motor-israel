---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  image?: string;
  overlay?: 'dark' | 'red';
  compact?: boolean;
  stats?: { value: string; label: string }[];
}

const {
  title,
  subtitle,
  ctaText = 'לקבלת הצעת מחיר',
  ctaHref = '/contact/',
  secondaryCtaText,
  secondaryCtaHref,
  image = '/images/hero/hero-lifestyle-atv-action.webp',
  overlay = 'dark',
  compact = false,
  stats,
} = Astro.props;

const overlayClass = overlay === 'red'
  ? 'from-access-900/85 via-access-800/60 to-access-700/30'
  : 'from-dark/85 via-dark/60 to-dark/30';
---

<section class:list={['relative overflow-hidden', compact ? 'min-h-[320px]' : 'min-h-[520px] md:min-h-[600px]']}>
  <!-- Background Image -->
  <img
    src={image}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    width="1920"
    height="1080"
    loading="eager"
    fetchpriority="high"
  />
  <!-- Gradient Overlay -->
  <div class:list={['absolute inset-0 bg-gradient-to-l', overlayClass]}></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 h-full flex items-center">
    <div class:list={['w-full', compact ? 'py-16' : 'py-20 md:py-28']}>
      <div class="max-w-2xl">
        <h1 class:list={[
          'font-extrabold text-white leading-tight mb-4',
          compact ? 'text-2xl md:text-3xl' : 'text-3xl md:text-4xl lg:text-5xl',
        ]}>
          {title}
        </h1>
        {subtitle && (
          <p class="text-lg md:text-xl text-gray-200 leading-relaxed mb-8">
            {subtitle}
          </p>
        )}
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={ctaHref}
            class="inline-flex items-center justify-center px-7 py-3.5 bg-access-500 text-white font-semibold rounded-sharp hover:bg-access-400 transition-all shadow-lg hover:shadow-xl text-lg"
          >
            {ctaText}
          </a>
          {secondaryCtaText && secondaryCtaHref && (
            <a
              href={secondaryCtaHref}
              class="inline-flex items-center justify-center px-7 py-3.5 border-2 border-white/70 text-white font-semibold rounded-sharp hover:bg-white/10 transition-all text-lg"
            >
              {secondaryCtaText}
            </a>
          )}
        </div>
        {stats && stats.length > 0 && (
          <div class="flex justify-between gap-4 mt-10 pt-8 border-t border-white/20">
            {stats.map((s) => (
              <div class="text-center">
                <p class="text-2xl sm:text-3xl font-bold text-access-400">{s.value}</p>
                <p class="text-xs sm:text-sm text-gray-300">{s.label}</p>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Accent bar -->
  <div class="absolute bottom-0 inset-x-0 h-1 bg-gradient-to-l from-access-400 via-access-500 to-access-600"></div>
</section>
