---

<div id="features" class="py-10">
  <h2 class="text-2xl font-bold text-dark mb-6">{title}</h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {features.map((feature, i) => (
      <div class="bg-white border border-border rounded-xl p-5 hover:border-access-300 hover:shadow-sm transition-all group">
        <div class="w-10 h-10 rounded-lg bg-access-50 flex items-center justify-center mb-3 group-hover:bg-access-500 transition-colors">
          <svg class="w-5 h-5 text-access-600 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icons[i % icons.length]} />
        </div>
        <p class="text-gray-700 text-sm leading-relaxed">{feature}</p>
      </div>
    ))}
  </div>
</div>
