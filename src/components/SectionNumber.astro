---
interface Props {
  number: string;
  title: string;
  subtitle?: string;
  align?: 'start' | 'center';
  dark?: boolean;
}

const { number, title, subtitle, align = 'start', dark = false } = Astro.props;
---

<div class:list={[
  'mb-10',
  align === 'center' ? 'text-center' : 'text-right'
]}>
  <div class:list={[
    'inline-flex items-center gap-3 mb-4',
    align === 'center' ? 'justify-center' : 'justify-start'
  ]}>
    <span class:list={[
      'text-5xl md:text-6xl font-black tracking-tighter',
      dark ? 'text-access-400/30' : 'text-access-200'
    ]}>{number}</span>
    <div class:list={['w-12 h-[2px]', dark ? 'bg-access-400' : 'bg-access-500']}></div>
  </div>
  <h2 class:list={[
    'text-3xl md:text-4xl font-bold mb-3',
    dark ? 'text-white' : 'text-dark'
  ]}>{title}</h2>
  {subtitle && (
    <p class:list={[
      'max-w-2xl text-lg leading-relaxed',
      dark ? 'text-gray-300' : 'text-gray-600',
      align === 'center' ? 'mx-auto' : ''
    ]}>{subtitle}</p>
  )}
</div>
