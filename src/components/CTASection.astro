---
interface Props {
  title?: string;
  subtitle?: string;
  phone?: string;
}

const {
  title = 'מעוניינים בטרקטורון Access אקסס?',
  subtitle = 'צרו קשר עוד היום לקבלת הצעת מחיר מותאמת אישית',
  phone = '077-230-7577',
} = Astro.props;
---

<section class="relative overflow-hidden bg-access-900 py-20">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23009FE3%22 fill-opacity=%221%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')] bg-repeat"></div>
  </div>

  <!-- Decorative elements -->
  <div class="absolute top-0 left-0 w-1/3 h-full bg-gradient-to-r from-access-950 to-transparent"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-access-600/20 rounded-full blur-3xl"></div>

  <!-- Diagonal accent line -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-access-500 via-access-400 to-access-500"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{title}</h2>
    <p class="text-access-200 text-lg md:text-xl mb-10 max-w-2xl mx-auto">{subtitle}</p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/contact/"
        class="group inline-flex items-center justify-center px-10 py-5 bg-access-600 text-white font-bold rounded-sharp hover:bg-access-400 transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 text-lg"
      >
        לקבלת הצעת מחיר
        <svg class="w-5 h-5 mr-2 rtl:rotate-180 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
      <a
        href={`tel:${phone}`}
        class="group inline-flex items-center justify-center px-10 py-5 border-2 border-white/30 text-white font-bold rounded-sharp hover:bg-white/10 hover:border-white/50 transition-all hover:-translate-y-1 text-lg"
      >
        <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        חייגו עכשיו: {phone}
      </a>
    </div>
  </div>

  <!-- Bottom diagonal accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-access-500 via-access-400 to-access-500"></div>
</section>
