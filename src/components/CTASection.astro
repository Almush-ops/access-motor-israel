---
interface Props {
  title?: string;
  subtitle?: string;
  phone?: string;
  image?: string;
}

const {
  title = 'מעוניינים בטרקטורון Access אקסס?',
  subtitle = 'צרו קשר עוד היום לקבלת הצעת מחיר מותאמת אישית',
  phone = '077-230-7577',
  image = '/images/hero/hero-sport-atv.webp',
} = Astro.props;
---

<section class="relative overflow-hidden min-h-[320px]">
  <!-- Background Image -->
  <img
    src={image}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    width="1920"
    height="640"
    loading="lazy"
  />
  <!-- Red overlay -->
  <div class="absolute inset-0 bg-access-600/85"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 py-16 text-center text-white">
    <h2 class="text-2xl md:text-3xl font-bold mb-3">{title}</h2>
    <p class="text-access-100 text-lg mb-8">{subtitle}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/contact/"
        class="inline-flex items-center justify-center px-8 py-4 bg-white text-access-600 font-semibold rounded-sharp hover:bg-access-50 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5 text-lg"
      >
        לקבלת הצעת מחיר
      </a>
      <a
        href={`tel:${phone}`}
        class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-semibold rounded-sharp hover:bg-white/10 transition-all hover:-translate-y-0.5 text-lg"
      >
        <svg class="w-5 h-5 me-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        חייגו עכשיו: {phone}
      </a>
    </div>
  </div>
</section>
