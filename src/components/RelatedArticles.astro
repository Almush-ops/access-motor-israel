---
interface Props {
  category: 'sport' | 'utility';
}

const { category } = Astro.props;

// Articles mapped to categories
const articlesByCategory = {
  sport: [
    { slug: 'buying-guide', title: 'מדריך קניית טרקטורון', description: 'כל מה שצריך לדעת לפני שקונים טרקטורון' },
    { slug: 'sport-vs-utility', title: 'טרקטורון ספורט או עבודה?', description: 'מה ההבדל ואיך בוחרים' },
    { slug: 'best-atv-for-beginners', title: 'טרקטורון למתחילים', description: 'הדגמים המומלצים לרוכבים חדשים' },
  ],
  utility: [
    { slug: 'buying-guide', title: 'מדריך קניית טרקטורון', description: 'כל מה שצריך לדעת לפני שקונים טרקטורון' },
    { slug: 'atv-maintenance', title: 'תחזוקת טרקטורון', description: '7 פעולות שכל בעלים חייב לדעת' },
    { slug: 'atv-accessories', title: 'אביזרים לטרקטורון', description: 'הציוד המומלץ לכל רוכב' },
  ],
};

const articles = articlesByCategory[category] || articlesByCategory.sport;
---

<section class="py-10 border-t border-border">
  <h2 class="text-2xl font-bold text-dark mb-6 flex items-center gap-2">
    <svg class="w-6 h-6 text-access-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
    </svg>
    מאמרים שיעניינו אתכם
  </h2>

  <div class="grid md:grid-cols-3 gap-4">
    {articles.map(article => (
      <a
        href={`/blog/${article.slug}/`}
        class="group p-5 bg-white rounded-xl border border-border hover:border-access-300 hover:shadow-md transition-all"
      >
        <h3 class="font-semibold text-dark group-hover:text-access-600 transition-colors mb-2">
          {article.title}
        </h3>
        <p class="text-sm text-gray-500 mb-3">{article.description}</p>
        <span class="text-sm text-access-600 font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
          קראו עוד
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
          </svg>
        </span>
      </a>
    ))}
  </div>
</section>
