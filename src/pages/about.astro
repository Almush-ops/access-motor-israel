---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CTASection from '@/components/CTASection.astro';
import SchemaOrg from '@/components/SchemaOrg.astro';

const siteUrl = 'https://access-motor.co.il';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Access Motor ישראל',
  url: siteUrl,
  description: 'מידע מקצועי על טרקטורונים Access Motor בישראל. ייעוץ, מפרטים והצעות מחיר.',
  telephone: '+972-77-230-7577',
  email: 'support@access-motor.co.il',
};

const breadcrumbs = [
  { label: 'אודות' },
];

const milestones = [
  { year: '1999', text: 'Access Motor נוסדה בטייוואן כיצרנית טרקטורונים' },
  { year: '2005', text: 'התחלת ייצוא לשווקים באירופה וצפון אמריקה' },
  { year: '2010', text: 'הרחבת קו הייצור לטרקטורוני עבודה (Utility ATVs)' },
  { year: '2016', text: 'MAX 650i משלים מסע 14,000+ ק"מ מהודו לאירופה - הישג בולט' },
  { year: '2020', text: 'נוכחות בלמעלה מ-50 מדינות עם מגוון דגמים' },
  { year: '2026', text: 'השקת הנציגות הרשמית בישראל דרך מטרו מוטור' },
];
---

<BaseLayout
  title="אודות Access Motor | יצרנית טרקטורונים מטייוואן מ-1999 | יבואן רשמי ישראל"
  description="Access Motor Co., Ltd. - יצרנית טרקטורונים טייוואנית עם 25+ שנות ניסיון. נוכחות ב-50+ מדינות. יבואן רשמי בישראל: מטרו מוטור שיווק (1981) בע&quot;מ."
>
  <SchemaOrg schema={orgSchema} />

  <Hero
    title="אודות Access Motor אקסס"
    subtitle="מותג טרקטורונים טייוואני עם יותר מ-25 שנות ניסיון באיכות ואמינות"
    compact
  />

  <div class="max-w-7xl mx-auto px-4 pt-8">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <!-- מה זה Access -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-dark mb-6">Access Motor - איכות טייוואנית מ-1999</h2>
          <div class="space-y-4 text-gray-700 leading-relaxed">
            <p>
              Access Motor Co., Ltd. היא יצרנית טרקטורונים טייוואנית המתמחה בפיתוח וייצור ATVs מאז 1999. החברה הוקמה עם חזון ברור - לייצר טרקטורונים איכותיים במחירים הוגנים, תוך שימת דגש על אמינות מנוע וחוזק מבנה.
            </p>
            <p>
              בניגוד למותגים אמריקאים ויפניים היקרים, Access מציעה יחס ערך מצוין - איכות ייצור גבוהה במחיר תחרותי. הדגמים עוברים בדיקות איכות מחמירות ומיוצרים בתנאי ISO מתקדמים במפעלי החברה בטייוואן.
            </p>
            <p>
              כיום, Access Motor מייצאת לעשרות מדינות באירופה, אמריקה, אוסטרליה ואסיה. המותג צבר מוניטין של אמינות ועמידות, במיוחד בשווקים האירופיים הדורשניים.
            </p>
          </div>
        </div>
        <div class="relative rounded-2xl overflow-hidden shadow-xl h-[350px]">
          <img
            src="/images/hero/hero-sport-atv.webp"
            alt="טרקטורון Access Motor"
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/40 to-transparent"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ציר זמן -->
  <section class="py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-dark mb-10 text-center">ההיסטוריה של Access Motor</h2>
      <div class="relative">
        <div class="absolute top-0 bottom-0 start-[18px] md:start-1/2 md:-translate-x-px w-0.5 bg-access-200"></div>

        <div class="space-y-8">
          {milestones.map((item, i) => (
            <div class:list={['relative flex items-start gap-6', i % 2 === 0 ? 'md:flex-row-reverse' : '']}>
              <div class="absolute start-[10px] md:start-1/2 md:-translate-x-1/2 w-4 h-4 rounded-full bg-access-500 border-4 border-white shadow-sm z-10 mt-1"></div>
              <div class:list={['ms-12 md:ms-0 md:w-[calc(50%-2rem)]', i % 2 === 0 ? 'md:me-auto md:text-end' : 'md:ms-auto']}>
                <span class="text-access-600 font-bold text-lg">{item.year}</span>
                <p class="text-gray-700 mt-1">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- יתרונות המותג -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-dark mb-3">למה לבחור Access?</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">יתרונות המותג הטייוואני שמציע ערך אמיתי לכסף</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', title: 'מחיר תחרותי', desc: 'טרקטורונים איכותיים במחירים נמוכים משמעותית ממותגים אמריקאים ויפניים, עם אותן יכולות.' },
          { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'אמינות מוכחת', desc: 'יותר מ-25 שנות ייצור עם מוניטין של מנועים עמידים וחלקים איכותיים.' },
          { icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z', title: 'מגוון דגמים', desc: 'מטרקטורון ספורט למתחילים ועד טרקטורון עבודה 800cc - פתרון לכל שימוש.' },
          { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'מנועים חזקים', desc: 'מנועים מ-300cc עד 800cc, כולל דגמי V-Twin, עם תיבות CVT אוטומטיות.' },
        ].map((tech) => (
          <div class="p-6 rounded-xl bg-surface border border-border hover:border-access-200 hover:shadow-md transition-all group">
            <div class="w-12 h-12 rounded-xl bg-access-100 flex items-center justify-center mb-4 group-hover:bg-access-500 transition-colors">
              <svg class="w-6 h-6 text-access-600 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={tech.icon} />
              </svg>
            </div>
            <h3 class="font-bold text-dark text-lg mb-2">{tech.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{tech.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- הישג בולט -->
  <section class="relative py-20 overflow-hidden">
    <img src="/images/hero/hero-utility-atv.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-dark/75"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center text-white">
      <p class="text-access-400 font-semibold tracking-widest uppercase mb-4">הישג בולט</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-6">14,000+ ק"מ מהודו לאירופה</h2>
      <p class="text-xl text-gray-300 leading-relaxed max-w-2xl mx-auto">
        ב-2016, רוכב הרפתקאות השלים מסע של למעלה מ-14,000 ק"מ על גבי Access MAX 650i - מהודו דרך פקיסטן, איראן, טורקיה ועד אירופה. המסע הוכיח את האמינות והעמידות של טרקטורוני Access בתנאים הקשים ביותר.
      </p>
    </div>
  </section>

  <!-- קטגוריות מוצרים -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-dark mb-8 text-center">2 קטגוריות - 6 דגמים</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {[
          { title: 'טרקטורוני ספורט', desc: 'טרקטורוני Sport עם מנועים מ-300cc עד 450cc. מתלים ארוכים, תגובה מהירה ורכיבת שטח מרגשת. מתאימים למתחילים ולרוכבים מנוסים כאחד.', href: '/sport/', count: '3 דגמים', image: '/images/hero/hero-sport-atv.webp' },
          { title: 'טרקטורוני עבודה', desc: 'טרקטורוני Utility רב-תכליתיים עם מנועים מ-300cc עד 800cc. ארגזי מטען, כננות ויכולת גרירה גבוהה. מתאימים לחקלאות, משקים ועבודות שטח.', href: '/utility/', count: '3 דגמים', image: '/images/hero/hero-utility-atv.webp' },
        ].map((cat) => (
          <a href={cat.href} class="group block rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all border border-border hover:border-access-200">
            <div class="relative h-56 overflow-hidden">
              <img src={cat.image} alt={cat.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent"></div>
              <span class="absolute bottom-3 start-3 bg-access-500 text-white text-xs font-bold px-3 py-1.5 rounded-full">{cat.count}</span>
            </div>
            <div class="p-6">
              <h3 class="font-bold text-dark text-xl mb-2 group-hover:text-access-600 transition-colors">{cat.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{cat.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- מספרים -->
  <section class="py-16 bg-surface">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { value: '50+', label: 'מדינות בעולם' },
          { value: '6', label: 'דגמים בישראל' },
          { value: '800cc', label: 'מנוע חזק ביותר' },
          { value: '25+', label: 'שנות ייצור' },
        ].map((stat) => (
          <div>
            <p class="text-3xl md:text-4xl font-extrabold text-access-600">{stat.value}</p>
            <p class="text-gray-600 mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- נציגות בישראל -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-dark mb-6">הנציגות בישראל</h2>
          <div class="space-y-4 text-gray-700 leading-relaxed">
            <p>
              טרקטורוני Access Motor מיובאים לישראל באופן רשמי ומגובים באחריות יצרן מקורית. היבואן הרשמי הוא חברת מטרו מוטור שיווק (1981) בע"מ - חברה ותיקה ומובילה בתחום ייבוא כלי רכב לישראל, עם ניסיון של למעלה מ-40 שנה בענף.
            </p>
            <p>
              מטרו מוטור שיווק בע"מ מייבאת ומפיצה מגוון מותגים מובילים בעולם כלי הרכב הדו-גלגלי, רכבי השטח והרכבים התפעוליים. החברה מפעילה רשת שירות ארצית עם מרכזי שירות מורשים בפריסה רחבה, ומספקת תמיכה טכנית, חלפים מקוריים ואחריות יצרן לכל הדגמים.
            </p>
            <p>
              כל טרקטורון Access שנמכר בישראל עובר בדיקה וטרום-מסירה מקצועית, ומגיע עם אחריות יצרן מקורית, ערכת שירות ראשונה ומדריך הפעלה בעברית.
            </p>
          </div>
        </div>
        <div class="space-y-4">
          {[
            { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'אחריות יצרן מקורית', desc: 'כל רכב מגיע עם אחריות יצרן מלאה ותמיכה מקצועית' },
            { icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', title: 'חלפים מקוריים', desc: 'מלאי חלפים מקוריים בישראל לזמינות מהירה' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'שירות ארצי', desc: 'רשת מרכזי שירות מורשים בפריסה ארצית' },
            { icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', title: 'הדרכה מקצועית', desc: 'הדרכת שימוש ובטיחות לכל רוכש חדש' },
          ].map((item) => (
            <div class="flex items-start gap-4 p-5 rounded-xl bg-surface border border-border">
              <div class="w-10 h-10 rounded-lg bg-access-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-access-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-dark mb-1">{item.title}</h3>
                <p class="text-gray-500 text-sm">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- יצירת קשר -->
  <section class="py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-dark mb-4">רוצים לדעת עוד?</h2>
      <p class="text-gray-600 mb-8 text-lg">
        לייעוץ מקצועי, מידע על הדגמים או הצעת מחיר - צרו קשר ונחזור אליכם בהקדם.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="inline-flex items-center justify-center px-8 py-3.5 bg-access-500 text-white font-semibold rounded-sharp hover:bg-access-400 transition-all shadow-lg hover:shadow-xl text-lg">
          לעמוד יצירת קשר
        </a>
        <a href="tel:077-230-7577" class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-access-500 text-access-600 font-semibold rounded-sharp hover:bg-access-50 transition-all text-lg">
          077-230-7577
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
