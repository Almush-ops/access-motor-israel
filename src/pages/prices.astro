---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PriceTable from '@/components/PriceTable.astro';
import CTASection from '@/components/CTASection.astro';
import SchemaOrg from '@/components/SchemaOrg.astro';
import { allModels, sportModels, utilityModels, formatPrice } from '@/lib/models-data';

const siteUrl = 'https://access-motor.co.il';

const breadcrumbs = [
  { label: 'מחירון' },
];

const productSchemas = allModels
  .filter((m) => m.price > 0)
  .map((model) => ({
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: model.name,
    description: `${model.categoryName} ${model.name} מבית Access Motor, מנוע ${model.engine}, ${model.seats} מקומות.`,
    brand: {
      '@type': 'Brand',
      name: 'Access Motor',
    },
    offers: {
      '@type': 'Offer',
      price: model.price,
      priceCurrency: 'ILS',
      availability: 'https://schema.org/InStock',
      url: `${siteUrl}/models/${model.slug}/`,
    },
  }));
---

<BaseLayout
  title="מחירון טרקטורונים Access Motor ישראל 2026 | 6 דגמים מ-₪26,990"
  description="מחירון Access Motor מעודכן 2026: TENA 300 ₪26,990, SP300 ₪32,990, SP400/AX650 ₪41,990, AMX800 ₪42,990, SP 450 Sport ₪44,990. כולל מע״מ, יבואן רשמי."
>
  <SchemaOrg schema={productSchemas} />

  <Hero
    title="מחירון Access Motor ישראל 2026"
    subtitle='מחירים עדכניים כולל מע"מ לכל דגמי Access'
    compact
  />

  <div class="max-w-7xl mx-auto px-4 pt-8">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <!-- Sport ATVs -->
  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-2">טרקטורוני ספורט</h2>
      <p class="text-gray-600 mb-6">טרקטורוני Sport עם מנועים מ-300cc עד 450cc, מתלים ארוכים ותגובה מהירה.</p>
      <PriceTable rows={sportModels} />
    </div>
  </section>

  <!-- Utility ATVs -->
  <section class="py-12 bg-surface">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-2">טרקטורוני שטח</h2>
      <p class="text-gray-600 mb-6">טרקטורוני Utility רב-תכליתיים עם מנועים מ-300cc עד 800cc, ארגזי מטען וכננות.</p>
      <PriceTable rows={utilityModels} />
    </div>
  </section>

  <!-- Price note -->
  <section class="py-8 bg-white">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <p class="text-gray-500 text-sm">
        המחירים כוללים מע"מ ועשויים להשתנות. לקבלת הצעת מחיר מעודכנת, <a href="/contact/" class="text-access-600 hover:text-access-700 underline">צרו קשר</a>.
      </p>
    </div>
  </section>

  <CTASection />
</BaseLayout>
