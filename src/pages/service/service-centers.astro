---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import FAQ from '@/components/FAQ.astro';
import CTASection from '@/components/CTASection.astro';

const breadcrumbs = [
  { label: 'שירות ותחזוקה', href: '/service/' },
  { label: 'מרכזי שירות' },
];

const northGarages = [
  { name: 'אופנועי הגליל', address: 'אזור תעשייה, כרמיאל', phone: '04-990-8877', specialties: 'טרקטורונים ספורט ועבודה', mapQuery: 'אזור תעשייה, כרמיאל, ישראל' },
  { name: 'מוטו צפון', address: 'רח\' הרצל 45, עפולה', phone: '04-652-3344', specialties: 'טרקטורונים, תחזוקה שוטפת', mapQuery: 'הרצל 45, עפולה, ישראל' },
  { name: 'שטח וכוח', address: 'רח\' הקורנס 18, חיפה', phone: '04-811-2233', specialties: 'כל הדגמים, מנועים ותמסורת', mapQuery: 'הקורנס 18, חיפה, ישראל' },
  { name: 'ATV סנטר', address: 'אזור תעשייה צמח, טבריה', phone: '04-672-5566', specialties: 'טרקטורונים, בלמים ומתלים', mapQuery: 'אזור תעשייה צמח, טבריה, ישראל' },
  { name: 'מוטו גולן', address: 'אזור תעשייה, קצרין', phone: '04-696-7788', specialties: 'כל הדגמים, שירות שטח', mapQuery: 'אזור תעשייה, קצרין, ישראל' },
];

const centerGarages = [
  { name: 'מוטוספורט מרכז', address: 'רח\' הברזל 30, ראשון לציון', phone: '03-942-1155', specialties: 'כל הדגמים, אבחון ממוחשב', mapQuery: 'הברזל 30, ראשון לציון, ישראל' },
  { name: 'פאוורספורט ישראל', address: 'רח\' ז\'בוטינסקי 7, פתח תקווה', phone: '03-911-3344', specialties: 'טרקטורוני עבודה, כננות', mapQuery: 'ז׳בוטינסקי 7, פתח תקווה, ישראל' },
  { name: 'גלגלי שטח', address: 'רח\' הפלדה 12, רחובות', phone: '08-936-2277', specialties: 'טרקטורונים, חלפים מקוריים', mapQuery: 'הפלדה 12, רחובות, ישראל' },
  { name: 'מוטו שרון', address: 'רח\' הרצל 102, נתניה', phone: '09-862-4455', specialties: 'כל הדגמים, תחזוקה שוטפת', mapQuery: 'הרצל 102, נתניה, ישראל' },
];

const southGarages = [
  { name: 'שטח דרום', address: 'אזור תעשייה צפוני, באר שבע', phone: '08-623-9900', specialties: 'כל הדגמים, שירות שטח', mapQuery: 'אזור תעשייה צפוני, באר שבע, ישראל' },
  { name: 'מוטו נגב', address: 'רח\' הבנאי 8, אשדוד', phone: '08-856-1122', specialties: 'טרקטורונים, בלמים ומתלים', mapQuery: 'הבנאי 8, אשדוד, ישראל' },
  { name: 'ATV אילת', address: 'אזור תעשייה שחמון, אילת', phone: '08-637-5544', specialties: 'כל הדגמים, שירות מדברי', mapQuery: 'אזור תעשייה שחמון, אילת, ישראל' },
];

const regions = [
  { title: 'אזור צפון', garages: northGarages },
  { title: 'אזור מרכז', garages: centerGarages },
  { title: 'אזור דרום', garages: southGarages },
];

const faq = [
  {
    question: 'איך בוחרים מרכז שירות?',
    answer: 'כל מרכזי השירות ברשימה הם מורשים ומוסמכים לטפל ברכבי Access. בחרו לפי קרבה גיאוגרפית ולפי ההתמחות הרלוונטית לדגם שלכם. בתקופת האחריות, מומלץ לפנות למרכז שירות מורשה בלבד.',
  },
  {
    question: 'האם ניתן להגיע ללא תיאום מראש?',
    answer: 'מומלץ לתאם מראש טלפונית כדי לוודא זמינות ולקצר זמני המתנה. במקרים דחופים ניתן להגיע ללא תיאום, אך ייתכן שתידרש המתנה.',
  },
  {
    question: 'האם מרכזי השירות מחזיקים חלפים מקוריים?',
    answer: 'מרכזי השירות המורשים עובדים עם חלפים מקוריים של Access בלבד. חלפים נפוצים נמצאים בדרך כלל במלאי. חלפים מיוחדים מוזמנים מהיבואן וזמן האספקה נע בין מספר ימים לשבועות.',
  },
  {
    question: 'מה לעשות במקרה של תקלה בשטח?',
    answer: 'צרו קשר טלפוני עם מרכז השירות הקרוב או עם מוקד השירות בטלפון 077-230-7577. נסו לתאר את התקלה ואת המיקום. במקרים מסוימים ניתן לקבל הכוונה טלפונית לפתרון בעיות פשוטות.',
  },
];
---

<BaseLayout
  title="מרכזי שירות מורשים Access אקסס | רשימת מוסכים ארצית"
  description="מרכזי שירות מורשים לטרקטורונים ורכבי שטח Access אקסס בישראל. 12 מוסכים מורשים בצפון, מרכז ודרום. טכנאים מוסמכים וחלפים מקוריים."
>
  <link slot="head" rel="preload" as="image" href="/images/hero/hero-utility-atv.webp" type="image/webp" />
  <Hero
    title="מרכזי שירות מורשים"
    subtitle="רשת מוסכים מורשים בפריסה ארצית לטרקטורונים ורכבי שטח Access אקסס"
    image="/images/hero/hero-utility-atv.webp"
    compact
    ctaText="חייגו עכשיו"
    ctaHref="tel:077-230-7577"
  />

  <div class="max-w-7xl mx-auto px-4 pt-8">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <!-- מידע כללי -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z', title: 'טכנאים מוסמכים', desc: 'כל הטכנאים עברו הכשרה מקצועית על ידי היצרן' },
          { icon: 'M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z', title: 'חלפים מקוריים', desc: 'שימוש בחלפים מקוריים של Access בלבד' },
          { icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z', title: 'שעות פעילות', desc: 'א׳-ה׳ 08:00-17:00 | ו׳ 08:30-13:00' },
        ].map((item) => (
          <div class="flex items-start gap-4 p-5 bg-surface rounded-xl border border-border">
            <div class="w-10 h-10 rounded-lg bg-access-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-access-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-dark mb-1">{item.title}</h3>
              <p class="text-gray-500 text-sm">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- רשימת מרכזי שירות לפי אזור -->
  {regions.map((region, regionIndex) => (
    <section class={`py-12 ${regionIndex % 2 === 0 ? 'bg-surface' : 'bg-white'}`}>
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-full bg-access-500 text-white flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-dark">{region.title}</h2>
            <p class="text-gray-500 text-sm">{region.garages.length} מרכזי שירות</p>
          </div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {region.garages.map((garage) => (
            <div class="bg-white rounded-xl overflow-hidden border border-border hover:border-access-200 hover:shadow-md transition-all">
              <div class="aspect-video">
                <iframe
                  src={`https://maps.google.com/maps?q=${encodeURIComponent(garage.mapQuery)}&t=&z=14&ie=UTF8&iwloc=&output=embed`}
                  class="w-full h-full border-0"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={`מפה - ${garage.name}`}
                ></iframe>
              </div>
              <div class="p-5">
                <h3 class="font-bold text-dark text-lg mb-2">{garage.name}</h3>
                <p class="text-gray-600 text-sm flex items-center gap-1.5 mb-2">
                  <svg class="w-4 h-4 text-access-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                  {garage.address}
                </p>
                <p class="text-gray-500 text-xs flex items-center gap-1.5 mb-3">
                  <svg class="w-4 h-4 text-access-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />
                  </svg>
                  {garage.specialties}
                </p>
                <a
                  href={`tel:${garage.phone.replace(/-/g, '')}`}
                  class="inline-flex items-center gap-2 px-4 py-2 bg-access-50 text-access-600 font-semibold rounded-sharp hover:bg-access-100 transition-colors text-sm"
                  dir="ltr"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                  {garage.phone}
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- הערה -->
  <section class="py-12 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <div class="bg-access-50 border border-access-200 rounded-xl p-6">
        <div class="flex items-start gap-3">
          <svg class="w-6 h-6 text-access-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
          </svg>
          <div>
            <h3 class="font-bold text-dark mb-1">חשוב לדעת</h3>
            <p class="text-gray-700 text-sm leading-relaxed">
              בתקופת האחריות, מומלץ לבצע את כל הטיפולים במרכזי שירות מורשים בלבד כדי לשמור על תוקף האחריות. לתיאום טיפול או לבירורים נוספים, ניתן לפנות ישירות למרכז השירות או למוקד השירות הארצי בטלפון
              <a href="tel:077-230-7577" class="font-semibold text-access-600 hover:text-access-700">077-230-7577</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-surface">
    <div class="max-w-3xl mx-auto px-4">
      <FAQ items={faq} title="שאלות נפוצות על מרכזי שירות" />
    </div>
  </section>

  <CTASection
    title="צריכים לתאם טיפול?"
    subtitle="חייגו עכשיו או השאירו פרטים ונחזור אליכם בהקדם"
  />
</BaseLayout>
