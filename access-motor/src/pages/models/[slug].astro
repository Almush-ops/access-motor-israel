---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import StickyProductNav from '@/components/StickyProductNav.astro';
import FeatureCards from '@/components/FeatureCards.astro';
import ModelSpecs from '@/components/ModelSpecs.astro';
import FAQ from '@/components/FAQ.astro';
import CTASection from '@/components/CTASection.astro';
import RelatedModels from '@/components/RelatedModels.astro';
import ContactForm from '@/components/ContactForm.astro';
import SchemaOrg from '@/components/SchemaOrg.astro';
import { allModels, formatPrice } from '@/lib/models-data';

export async function getStaticPaths() {
  const models = await getCollection('models');
  return models.map((model) => ({
    params: { slug: model.data.slug },
    props: { model },
  }));
}

const { model } = Astro.props;
const { Content } = await render(model);
const d = model.data;
// Price from models-data.ts (single source of truth for all prices)
const price = allModels.find(m => m.slug === d.slug)?.price ?? d.price;
const siteUrl = 'https://access-motor.co.il';

const breadcrumbs = [
  { label: d.categoryName, href: `/${d.categorySlug}/` },
  { label: d.name },
];

const categoryLabels: Record<string, string> = {
  'sport': 'טרקטורון ספורט',
  'utility': 'טרקטורון עבודה',
};

const productSchema = price > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${d.name} - Access Motor`,
  description: d.description,
  image: `${siteUrl}${d.image || '/images/models/' + d.slug + '.webp'}`,
  brand: { '@type': 'Brand', name: 'Access Motor' },
  offers: {
    '@type': 'Offer',
    price: price,
    priceCurrency: 'ILS',
    availability: 'https://schema.org/InStock',
    url: `${siteUrl}/models/${d.slug}/`,
    seller: {
      '@type': 'Organization',
      name: 'מטרו מוטור שיווק בע"מ',
    },
  },
} : null;

// Extract key specs for highlight cards
const keySpecs = d.specs.slice(0, 4);
---

<BaseLayout title={d.title} description={d.description} ogImage={d.image || `/images/models/${d.slug}.webp`} ogType="product">
  {productSchema && <SchemaOrg schema={productSchema} />}

  <!-- 1. Hero Section -->
  <section id="product-hero" class="bg-surface">
    <div class="max-w-6xl mx-auto px-4 pt-6 pb-10">
      <Breadcrumbs items={breadcrumbs} />

      <div class="grid md:grid-cols-2 gap-8 items-center mt-4">
        <!-- Image (first on mobile) -->
        <div class="relative bg-gradient-to-br from-gray-100 via-white to-gray-200 rounded-2xl overflow-hidden shadow-sm">
          <img
            src={d.image || `/images/models/${d.slug}.webp`}
            alt={`${d.name} - Access אקסס`}
            class="w-full h-auto md:h-[420px] md:object-cover relative z-10"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute bottom-0 inset-x-0 h-1 bg-gradient-to-l from-access-400 via-access-500 to-access-600"></div>
        </div>

        <!-- Product Info -->
        <div>
          <div class="flex items-center gap-2 mb-3 flex-wrap">
            <span class="text-sm font-medium px-3 py-1 rounded-full bg-access-100 text-access-700">
              {categoryLabels[d.category]}
            </span>
            {d.badge && (
              <span class="text-sm font-medium px-3 py-1 rounded-full bg-gray-100 text-gray-600">
                {d.badge}
              </span>
            )}
            <span class="text-sm text-gray-500">{d.engine} · {d.seats === 1 ? 'רוכב אחד' : `${d.seats} מקומות`}</span>
          </div>

          <h1 class="text-3xl md:text-4xl font-extrabold text-dark mb-4">{d.name}</h1>
          <p class="text-gray-600 mb-6 leading-relaxed">{d.description}</p>

          <div class="flex items-baseline gap-2 mb-8">
            <span class="text-sm text-gray-500">החל מ-</span>
            <span class="text-3xl font-bold text-access-600">{formatPrice(price)}</span>
            {price > 0 && <span class="text-sm text-gray-500">כולל מע"מ</span>}
          </div>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href="#contact" class="inline-flex items-center justify-center px-8 py-3.5 bg-access-500 text-white font-semibold rounded-sharp hover:bg-access-600 transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 text-lg">
              {price > 0 ? 'לקבלת הצעת מחיר' : 'בקשו הצעת מחיר'}
            </a>
            <a href="tel:077-230-7577" class="inline-flex items-center justify-center px-6 py-3.5 border-2 border-access-200 text-access-700 font-semibold rounded-sharp hover:bg-access-50 transition-all">
              <svg class="w-5 h-5 me-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              077-230-7577
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Specs Highlight (if specs exist) -->
  {keySpecs.length > 0 && (
    <section class="bg-white border-b border-border">
      <div class="max-w-6xl mx-auto px-4 py-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {keySpecs.map((spec: {label: string; value: string}) => (
            <div class="text-center p-3">
              <p class="text-xl md:text-2xl font-bold text-access-600">{spec.value}</p>
              <p class="text-xs text-gray-500 mt-1">{spec.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 2. Sticky Navigation -->
  <StickyProductNav hasFeatures={d.features.length > 0} hasSpecs={d.specs.length > 0} hasFaq={d.faq.length > 0} />

  <!-- Main content area -->
  <div class="max-w-4xl mx-auto px-4">

    <!-- 3. Overview (markdown content) -->
    <section id="overview" class="py-10">
      <div class="prose max-w-none">
        <Content />
      </div>
    </section>

    <!-- 4. Features -->
    {d.features.length > 0 && (
      <div class="border-t border-border">
        <FeatureCards features={d.features} title={`יתרונות ${d.name}`} />
      </div>
    )}

    <!-- 5. Specs -->
    {d.specs.length > 0 && (
      <div class="border-t border-border">
        <ModelSpecs specs={d.specs} title={`מפרט טכני - ${d.name}`} />
      </div>
    )}

    <!-- 6. FAQ -->
    {d.faq.length > 0 && (
      <div class="border-t border-border">
        <FAQ items={d.faq} title={`שאלות נפוצות - ${d.name}`} />
      </div>
    )}
  </div>

  <!-- Technology & Warranty Info -->
  <section class="bg-surface py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-border">
          <div class="w-10 h-10 rounded-lg bg-access-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-access-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-1">אחריות יצרן</h3>
            <p class="text-gray-500 text-sm">אחריות יצרן מקורית עם תמיכה מקצועית בישראל</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-border">
          <div class="w-10 h-10 rounded-lg bg-access-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-access-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-1">חלפים מקוריים</h3>
            <p class="text-gray-500 text-sm">מלאי חלפים זמין בישראל לתחזוקה מהירה</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-border">
          <div class="w-10 h-10 rounded-lg bg-access-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-access-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-1">שירות ארצי</h3>
            <p class="text-gray-500 text-sm">רשת מרכזי שירות מורשים בפריסה ארצית</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. CTA -->
  <CTASection />

  <!-- 8. Related Models -->
  <div class="max-w-6xl mx-auto px-4">
    <RelatedModels currentSlug={d.slug} categorySlug={d.categorySlug} />
  </div>

  <!-- 9. Contact Form -->
  <section id="contact" class="bg-surface">
    <div class="max-w-2xl mx-auto px-4 py-12">
      <ContactForm title={`הצעת מחיר - ${d.name}`} />
    </div>
  </section>
</BaseLayout>
