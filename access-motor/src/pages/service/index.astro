---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import FAQ from '@/components/FAQ.astro';
import CTASection from '@/components/CTASection.astro';

const breadcrumbs = [
  { label: 'שירות ותחזוקה' },
];

const serviceCategories = [
  {
    icon: 'M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085',
    title: 'טיפול שוטף',
    desc: 'טיפולים תקופתיים לפי יצרן: החלפת שמן מנוע, פילטרים, נוזל קירור ובדיקת מערכות. מומלץ כל 6 חודשים או 1,000 ק"מ.',
  },
  {
    icon: 'M21 7.5V18M15 7.5V18M3 16.811V8.69c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 010 1.954l-7.108 4.061A1.125 1.125 0 013 16.811z',
    title: 'מנוע ותמסורת',
    desc: 'אבחון ותיקון מנועים מ-300cc עד 800cc, תיבות CVT אוטומטיות, מערכות הנעה כפולה 2WD/4WD ודיפרנציאלים.',
  },
  {
    icon: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
    title: 'בלמים ומתלים',
    desc: 'החלפת רפידות ודיסקי בלם, שיפוץ מתלים עצמאיים, בולמי זעזועים, כיוון גאומטריה וטיפול במערכת ההיגוי ו-EPS.',
  },
  {
    icon: 'M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25h17.25M3.375 14.25a1.125 1.125 0 01-1.125-1.125V3.375c0-.621.504-1.125 1.125-1.125h14.25c.621 0 1.125.504 1.125 1.125v9.75M3.375 14.25h1.5C5.496 14.25 6 14.754 6 15.375v1.5c0 .621-.504 1.125-1.125 1.125H3.375m17.25-3h-1.5a1.125 1.125 0 00-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125h1.5',
    title: 'שלדה וגוף',
    desc: 'תיקון ושיקום שלדות, החלפת פלסטיקה, מגני תחתית, כננות, צמיגים וחישוקי אלומיניום מקוריים.',
  },
  {
    icon: 'M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z',
    title: 'חלפים מקוריים',
    desc: 'מלאי חלפים מקוריים של Access זמין בישראל. פילטרים, רפידות, רצועות CVT, נוזלים ועוד - לתחזוקה מהירה ואמינה.',
  },
  {
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
    title: 'אחריות יצרן',
    desc: 'כל רכב Access מגיע עם אחריות יצרן מקורית. ביצוע טיפולים במרכזי שירות מורשים שומר על תוקף האחריות.',
  },
];

const maintenanceTips = [
  { icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z', title: 'טיפול תקופתי', desc: 'בצעו טיפול שוטף כל 6 חודשים או 1,000 ק"מ - המוקדם מבניהם. טיפול סדיר מאריך את חיי הרכב.' },
  { icon: 'M6 13.5V3.75m0 9.75a1.5 1.5 0 010 3m0-3a1.5 1.5 0 000 3m0 3.75V16.5m12-3V3.75m0 9.75a1.5 1.5 0 010 3m0-3a1.5 1.5 0 000 3m0 3.75V16.5m-6-9V3.75m0 3.75a1.5 1.5 0 010 3m0-3a1.5 1.5 0 000 3m0 9.75V10.5', title: 'לחץ אוויר בצמיגים', desc: 'בדקו לחץ אוויר בצמיגים אחת לשבוע. לחץ לא תקין פוגע בשליטה, בצריכת דלק ובבלאי הצמיג.' },
  { icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z', title: 'בדיקת מערכת חשמל', desc: 'ודאו שכל התאורה, המצברים והחיבורים החשמליים תקינים. בדקו מתח מצבר ונקו קוטבים בעת הצורך.' },
  { icon: 'M21 12a9 9 0 11-18 0 9 9 0 0118 0z M9 9.563C9 9.252 9.252 9 9.563 9h4.874c.311 0 .563.252.563.563v4.874c0 .311-.252.563-.563.563H9.564A.562.562 0 019 14.437V9.564z', title: 'החלפת שמן מנוע', desc: 'החליפו שמן מנוע ופילטר שמן בכל טיפול. שמן נקי מגן על חלקי המנוע ומבטיח ביצועים מיטביים.' },
  { icon: 'M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z', title: 'ניקוי אחרי נסיעת שטח', desc: 'שטפו את הרכב אחרי כל נסיעת שטח. הסירו בוץ, חול ועלים ממערכות הקירור, פילטר האוויר והמתלים.' },
  { icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z', title: 'אחסון נכון', desc: 'אם הרכב לא בשימוש לתקופה ממושכת - נתקו מצבר, מלאו דלק (למניעת חלודה) ואחסנו במקום מוצל ויבש.' },
];

const faq = [
  {
    question: 'כל כמה זמן צריך לעשות טיפול לטרקטורון Access?',
    answer: 'מומלץ לבצע טיפול שוטף כל 6 חודשים או 1,000 ק"מ, המוקדם מביניהם. הטיפול כולל החלפת שמן מנוע ופילטרים, בדיקת בלמים ומתלים, בדיקת רמות נוזלים ובדיקה כללית של המערכות. בנסיעות אינטנסיביות בשטח, ייתכן שיידרש טיפול תכוף יותר.',
  },
  {
    question: 'האם אני חייב לעשות טיפולים במרכז שירות מורשה?',
    answer: 'בתקופת האחריות, מומלץ מאוד לבצע את כל הטיפולים במרכזי שירות מורשים בלבד, כדי לשמור על תוקף האחריות. הטכנאים המורשים מוכשרים על ידי היצרן ומשתמשים בחלפים מקוריים בלבד. לאחר תקופת האחריות, תוכלו לבחור היכן לטפל ברכב.',
  },
  {
    question: 'מה כולל הטיפול השוטף?',
    answer: 'טיפול שוטף כולל: החלפת שמן מנוע ופילטר שמן, בדיקת/החלפת פילטר אוויר, בדיקת רמת נוזל קירור ונוזל בלמים, בדיקת לחץ אוויר בצמיגים ובלאי, בדיקת רפידות בלם ודיסקים, בדיקת מתלים ובולמי זעזועים, בדיקת חגורת CVT, בדיקת מערכת חשמל ותאורה, ובדיקה כללית של הרכב.',
  },
  {
    question: 'האם יש חלפים מקוריים של Access בישראל?',
    answer: 'כן. מלאי חלפים מקוריים של Access Motor זמין בישראל באמצעות היבואן הרשמי. חלפים נפוצים כגון פילטרים, רפידות בלם, רצועות CVT, נוזלים ושמנים זמינים במלאי שוטף. חלפים מיוחדים ניתן להזמין וזמן האספקה נע בין מספר ימים לשבועות.',
  },
  {
    question: 'מה האחריות על רכבי Access בישראל?',
    answer: 'כל רכב Access מגיע עם אחריות יצרן מקורית. האחריות מכסה פגמים בחומרים ובייצור, ומותנית בביצוע טיפולים תקופתיים לפי הנחיות היצרן. לפרטים מלאים על תנאי האחריות, פנו אלינו.',
  },
];
---

<BaseLayout
  title="שירות ותחזוקה Access אקסס | טיפולים, חלפים ואחריות"
  description="שירות ותחזוקה לטרקטורונים ורכבי שטח Access אקסס. טיפולים תקופתיים, חלפים מקוריים, אחריות יצרן ומרכזי שירות מורשים בפריסה ארצית. 077-230-7577."
>
  <link slot="head" rel="preload" as="image" href="/images/hero/hero-fugleman-wallpaper.webp" type="image/webp" />
  <Hero
    title="שירות ותחזוקה Access אקסס"
    subtitle="טיפולים מקצועיים, חלפים מקוריים ואחריות יצרן - כדי שהרכב שלכם יישאר בכושר מלא"
    image="/images/hero/hero-fugleman-wallpaper.webp"
    compact
    ctaText="למרכזי שירות"
    ctaHref="/service/service-centers/"
  />

  <div class="max-w-7xl mx-auto px-4 pt-8">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <!-- שירותים -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-dark mb-3">שירותי תחזוקה ותיקון</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">מגוון שירותים מקצועיים לטרקטורוני ספורט ועבודה של Access אקסס</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {serviceCategories.map((service) => (
          <div class="p-6 rounded-xl bg-surface border border-border hover:border-access-200 hover:shadow-md transition-all group">
            <div class="w-12 h-12 rounded-xl bg-access-100 flex items-center justify-center mb-4 group-hover:bg-access-500 transition-colors">
              <svg class="w-6 h-6 text-access-600 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
              </svg>
            </div>
            <h3 class="font-bold text-dark text-lg mb-2">{service.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- טיפים לתחזוקה -->
  <section class="py-16 bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-dark mb-3">טיפים לתחזוקת הרכב</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">6 דברים שתוכלו לעשות בעצמכם כדי לשמור על הרכב במצב מיטבי</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {maintenanceTips.map((tip, i) => (
          <div class="flex items-start gap-4 p-5 bg-white rounded-xl border border-border">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-access-500 text-white flex items-center justify-center font-bold text-sm">
              {i + 1}
            </div>
            <div>
              <h3 class="font-bold text-dark mb-1">{tip.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{tip.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- כמה עולה טיפול -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-dark mb-8 text-center">מה כולל כל טיפול?</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse bg-white rounded-xl overflow-hidden shadow-sm">
          <thead>
            <tr class="bg-access-50">
              <th class="text-start p-4 font-semibold text-dark border-b border-access-100">סוג טיפול</th>
              <th class="text-center p-4 font-semibold text-dark border-b border-access-100">תדירות</th>
              <th class="text-start p-4 font-semibold text-dark border-b border-access-100">כולל</th>
            </tr>
          </thead>
          <tbody>
            <tr class="hover:bg-access-50/50 transition-colors">
              <td class="p-4 font-medium text-dark border-b border-gray-100">טיפול שוטף</td>
              <td class="text-center p-4 border-b border-gray-100">כל 6 חודשים / 1,000 ק"מ</td>
              <td class="p-4 border-b border-gray-100 text-gray-600">שמן מנוע, פילטרים, בדיקת בלמים, מתלים, נוזלים ומערכות</td>
            </tr>
            <tr class="hover:bg-access-50/50 transition-colors">
              <td class="p-4 font-medium text-dark border-b border-gray-100">טיפול מורחב</td>
              <td class="text-center p-4 border-b border-gray-100">כל 12 חודשים / 3,000 ק"מ</td>
              <td class="p-4 border-b border-gray-100 text-gray-600">כל הנ"ל + רצועת CVT, נוזל קירור, בדיקת דיפרנציאל ומערכת הנעה</td>
            </tr>
            <tr class="hover:bg-access-50/50 transition-colors">
              <td class="p-4 font-medium text-dark border-b border-gray-100">טיפול בלמים</td>
              <td class="text-center p-4 border-b border-gray-100">לפי בלאי</td>
              <td class="p-4 border-b border-gray-100 text-gray-600">החלפת רפידות, בדיקת/החלפת דיסקים, נוזל בלמים, כיוון</td>
            </tr>
            <tr class="hover:bg-access-50/50 transition-colors">
              <td class="p-4 font-medium text-dark">טיפול מתלים</td>
              <td class="text-center p-4">לפי בלאי / פעם בשנתיים</td>
              <td class="p-4 text-gray-600">בדיקת בולמי זעזועים, סילנטבלוקים, ברגים, כיוון גאומטריה</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- קישור למרכזי שירות -->
  <section class="py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="bg-white rounded-2xl p-8 md:p-12 border border-border shadow-sm">
        <div class="w-16 h-16 rounded-2xl bg-access-100 flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-access-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-dark mb-3">מרכזי שירות מורשים</h2>
        <p class="text-gray-600 mb-6 max-w-xl mx-auto">
          רשת מרכזי שירות מורשים בפריסה ארצית - צפון, מרכז ודרום. טכנאים מוסמכים, חלפים מקוריים ושירות מקצועי.
        </p>
        <a href="/service/service-centers/" class="inline-flex items-center justify-center px-8 py-3.5 bg-access-500 text-white font-semibold rounded-sharp hover:bg-access-600 transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 text-lg">
          לרשימת מרכזי השירות
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <FAQ items={faq} title="שאלות נפוצות על שירות ותחזוקה" />
    </div>
  </section>

  <CTASection
    title="צריכים טיפול או ייעוץ?"
    subtitle="צרו קשר לתיאום טיפול, הזמנת חלפים או כל שאלה על תחזוקת הרכב"
  />
</BaseLayout>
