---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="תודה שפנית אלינו - Access Motor ישראל"
  description="הפנייה התקבלה בהצלחה. נציג Access Motor ישראל יחזור אליך בהקדם."
  noindex={true}
>
  <section class="py-24">
    <div class="max-w-lg mx-auto px-4 text-center">
      <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-access-50 flex items-center justify-center">
        <svg class="w-10 h-10 text-access-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <h1 class="text-3xl font-bold text-dark mb-4">תודה שפנית אלינו!</h1>
      <p class="text-gray-600 text-lg mb-8 leading-relaxed">
        הפנייה שלך התקבלה בהצלחה. נציג Access Motor ישראל יחזור אליך בהקדם האפשרי.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center justify-center px-6 py-3 bg-access-500 text-white font-semibold rounded-md hover:bg-access-600 transition-colors">
          חזרה לדף הבית
        </a>
        <a href="/prices/" class="inline-flex items-center justify-center px-6 py-3 border-2 border-access-500 text-access-600 font-semibold rounded-md hover:bg-access-50 transition-colors">
          צפו במחירון
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
